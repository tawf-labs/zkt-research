@startuml
skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName Times-Roman
skinparam defaultFontSize 10
skinparam rectangleBorderThickness 1.5
skinparam dpi 300


rectangle "1. Wallet Connect\n& Privacy Tier Select" as S1
rectangle "2. proposeOrganizer()\nsubmits KYC application" as S2
rectangle "3. createProposal()\ncreates campaign with milestones" as S3
rectangle "4. submitForCommunityVote()\nopens tiered voting" as S4
rectangle "5. finalizeCommunityVote()\ntallies votes, triggers sharia review" as S5
rectangle "6. reviewProposal()\nGroth16 ZK proof submission" as S6
rectangle "7. createCampaignPool()\ninitializes campaign fund pool" as S7
rectangle "8. donateZK() / donateZKPrivate()\nverifies proof, routes funds,\nmints SBT receipt" as S8

S1 -down-> S2
S2 -down-> S3
S3 -down-> S4
S4 -down-> S5
S5 -down-> S6
S6 -down-> S7
S7 -down-> S8

@enduml
