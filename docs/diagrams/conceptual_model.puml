@startuml
skinparam backgroundColor transparent
skinparam shadowing false
skinparam defaultFontName Arial
skinparam defaultFontSize 11
skinparam ArrowColor #888780
skinparam ArrowThickness 1
skinparam linetype ortho

skinparam rectangle {
  BorderColor #888780
  BorderThickness 0.5
  RoundCorner 8
}

skinparam package {
  BorderColor #888780
  BorderThickness 0.8
  BorderStyle dashed
  RoundCorner 10
  FontStyle plain
  FontSize 10
}

actor Donor

' ── Left column: Off-chain ──
package "Off-chain proving pipeline" {
  rectangle "Witness generation\nnargo execute" as Witness
  rectangle "Noir circuit\n29 ACIR opcodes" as Circuit
  rectangle "Barretenberg bb v4.2.1" as BB
  rectangle "UltraHONK proof\n8,384 B · 246.8 ms" as Proof
}

' ── Middle column: On-chain ──
package "Ethereum Sepolia (block 10,854,651)" {

  package "Core" {
    rectangle "ZKVerifier\n0x1009…2f3F" as Verifier
    rectangle "ZKTCore v8\n0xb56a…B60B" as ZKTCore
    rectangle "NullifierRegistry\n0xeEA8…9e49" as Nullifier
  }

  package "Governance" {
    rectangle "ProposalManager\n0xc75f…7911" as PropMgr
    rectangle "VotingManager\n0x56CA…Fb4" as VoteMgr
    rectangle "VotingNFT\n0x62AF…89B4" as VNFT
    rectangle "ShariaReviewMgr\n0x227c…3af2" as ShariaMgr
  }

  package "Finance" {
    rectangle "PoolManager\n0x8b74…288c" as PoolMgr
    rectangle "ZakatEscrowMgr\n0x8A08…eED1" as Escrow
    rectangle "DonationReceiptNFT\n0x739b…1885" as NFT
  }
}

' ── Right column: Frontend ──
package "Frontend · Next.js 15 PWA" {
  rectangle "wagmi + XellarKit\nwallet" as Wallet
  rectangle "usePrivateDonation\nhook" as Hook
  rectangle "Privacy tier\ntoggle" as Toggle
}

' ── Off-chain flow (left, vertical) ──
Donor   -down-> Witness : private inputs
Witness -down-> Circuit : Prover.toml
Circuit -down-> BB      : ACIR bytecode
BB      -down-> Proof   : prove (246.8 ms)

' ── Proof → Verifier (cross) ──
Proof   -right-> Verifier : 8,384 B proof

' ── On-chain: Verifier → ZKTCore → Nullifier ──
Verifier -down-> ZKTCore   : verify OK
ZKTCore  -down-> Nullifier : spend(nullifier)

' ── Governance flow: ZKTCore orchestrates rightward ──
ZKTCore  -right-> PropMgr   : createProposal
ZKTCore  -right-> VoteMgr   : submitForCommunityVote
ZKTCore  -right-> ShariaMgr : finalizeShariaBundle
ZKTCore  -right-> PoolMgr   : createCampaignPool
ZKTCore  -right-> Escrow    : donateZK()

' ── Escrow → NFT → Donor ──
Escrow   -right-> NFT    : mint SBT
NFT      -right-> Donor  : SBT receipt

' ── Frontend flow (right) ──
Donor    -right-> Wallet : connect Sepolia
Wallet   -down-> Hook    : call donateZK()
Hook     -down-> Toggle  : select tier
Hook     -down-> Proof   : fetch proof
Hook     -right-> ZKTCore : submit tx (721,345 gas)

@enduml