@startuml
skinparam backgroundColor transparent
skinparam shadowing false
skinparam defaultFontName Arial
skinparam defaultFontSize 12
skinparam ArrowColor #888780
skinparam ArrowThickness 1
skinparam linetype ortho
skinparam dpi 300

skinparam rectangle {
  BorderColor #888780
  BorderThickness 0.5
  RoundCorner 8
}

skinparam package {
  BorderColor #888780
  BorderThickness 0.8
  BorderStyle dashed
  RoundCorner 10
  FontStyle plain
  FontSize 10
}

actor Donor
actor Organizer

' ── Left column: Off-chain ──
package "Off-chain proving" {
  rectangle "Witness\nnargo execute" as Witness
  rectangle "Noir circuit\n29 ACIR opcodes" as Circuit
  rectangle "Barretenberg bb" as BB
  rectangle "UltraHONK proof\n8,384 B, 270 ms" as Proof
}

' ── Middle column: On-chain ──
package "Ethereum Sepolia" {

  package "Core" {
    rectangle "ZKVerifier" as Verifier
    rectangle "Groth16Verifier" as Groth16
    rectangle "ZKTCore" as ZKTCore
    rectangle "NullifierRegistry" as Nullifier
  }

  package "Governance" {
    rectangle "ProposalManager" as PropMgr
    rectangle "VotingManager" as VoteMgr
    rectangle "ShariaReviewMgr" as ShariaMgr
    rectangle "PrivateDonationPool" as PrivatePool
    rectangle "PoolManager" as PoolMgr
    rectangle "ZakatEscrowMgr" as Escrow
    rectangle "MilestoneManager" as MilestoneMgr
    rectangle "DonationReceiptNFT" as NFT
  }

  package "Identity" {
    rectangle "VotingNFT" as VotingNFT
    rectangle "OrganizerNFT" as OrganizerNFT
    rectangle "ParticipationTracker" as Tracker
  }
}

' ── Right column: Frontend ──
package "Frontend" {
  rectangle "wagmi + XellarKit" as Wallet
  rectangle "donation hook" as Hook
  rectangle "Privacy tier\ntoggle" as Toggle
}

' ── Off-chain flow ──
Donor   -down-> Witness : inputs
Witness -down-> Circuit : Prover.toml
Circuit -down-> BB      : ACIR
BB      -down-> Proof   : prove

' ── Proof → Verifier ──
Proof   -right-> Verifier : proof

' ── On-chain flow ──
Verifier -down-> ZKTCore   : verify OK
ZKTCore  -down-> Nullifier : spend

' ── Governance flow ──
Groth16 --> ShariaMgr : verifies
ZKTCore  -right-> PropMgr   : proposal
ZKTCore  -right-> VoteMgr   : voting
ZKTCore  -right-> ShariaMgr : review
ZKTCore  -right-> PrivatePool : private donate
ZKTCore  -right-> Escrow    : public donate
ZKTCore  -right-> PoolMgr   : campaign pool
ZKTCore  -right-> MilestoneMgr : milestones
PrivatePool ..> Escrow    : redistribute

' ── NFT flow ──
Escrow   -right-> NFT    : mint SBT
NFT      -right-> Donor  : receipt

' ── Organizer flow ──
Organizer -down-> OrganizerNFT : KYC
Organizer -down-> VotingNFT : voting
Organizer -down-> Tracker : metrics

' ── Frontend flow ──
Donor    -right-> Wallet : connect
Wallet   -down-> Hook    : donate
Hook     -down-> Toggle  : tier
Hook     -down-> Proof   : fetch
Hook     -right-> ZKTCore : submit tx

@enduml
